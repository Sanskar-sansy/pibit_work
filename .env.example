# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# Database
DATABASE_URL=sqlite:///./runs/experiments.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Paths
DATA_DIR=./data
REPORTS_DIR=./reports
RUNS_DIR=./runs
CACHE_DIR=./data/cache

# Experiment
EXPERIMENT_NAME=default_run
RANDOM_SEED=42
